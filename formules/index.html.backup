<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Formulaires d'électrotechnique - Page d'accueil avec sommaire des chapitres">
    <meta name="author" content="Denis (DS_de_Mo) - Modernisé par Garibobo 2026">
    <title>Formulaires Électrotechnique Garibobo - Accueil</title>
    
    <!-- MathJax pour rendu des formules mathématiques -->
    <script src="https://polyfill.io/v3/polyfill.min.js?features=es6"></script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <script>
        MathJax = {
            tex: {
                inlineMath: [['$', '$'], ['\\(', '\\)']],
                displayMath: [['$$', '$$'], ['\\[', '\\]']]
            },
            svg: {
                fontCache: 'global',
                scale: 1.8,
                minScale: 1.6,
                mtextInheritFont: true
            },
            chtml: {
                scale: 1.8,
                minScale: 1.6,
                mtextInheritFont: true
            },
            options: {
                enableMenu: false,
                renderActions: {
                    addMenu: []
                }
            }
        };
    </script>
    
    <!-- CSS Moderne -->
    <link rel="stylesheet" href="../assets/css/style.css">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=JetBrains+Mono:wght@400;600&family=Oswald:wght@300;400;500;600;700&family=EB+Garamond:ital,wght@0,400;0,600;1,400&family=Source+Code+Pro:wght@400;600&display=swap" rel="stylesheet">
    
    <style>
        /* Styles spécifiques pour les tableaux de formules */
        body {
            font-size: 18px;
            line-height: 1.8;
            margin: 0;
            padding: 0;
        }
        
        /* Styles MathJax optimisés pour grand écran et PDF */
        .MathJax, .MathJax_Display, .MathJax_SVG, .MathJax_CHTML {
            font-size: 1.8em !important;
            line-height: 2.2 !important;
            margin: 0.6em 0 !important;
        }
        
        .formula-table .MathJax,
        .formula-table .MathJax_Display,
        .formula-table .MathJax_SVG,
        .formula-table .MathJax_CHTML {
            font-size: 1.8em !important;
            font-weight: 500 !important;
            letter-spacing: 0.03em !important;
        }
        
        td .MathJax,
        p .MathJax {
            font-size: 1.8em !important;
            vertical-align: middle !important;
        }
        
        @media print {
            .MathJax, .MathJax_Display, .MathJax_SVG, .MathJax_CHTML {
                font-size: 1.9em !important;
                page-break-inside: avoid !important;
            }
        }
        
        @media screen and (min-width: 1920px) {
            .MathJax, .MathJax_Display, .MathJax_SVG, .MathJax_CHTML {
                font-size: 2em !important;
            }
            .formula-table .MathJax {
                font-size: 2em !important;
            }
        }
        
        /* Layout avec sidebar */
        .page-wrapper {
            display: flex;
            min-height: 100vh;
        }
        
        /* Menu latéral gauche (sidebar) */
        .sidebar {
            width: 280px;
            background: linear-gradient(180deg, #047857 0%, #14b8a6 100%);
            color: white;
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            padding: 30px 0;
            box-shadow: 4px 0 10px rgba(0, 0, 0, 0.1);
            z-index: 100;
        }
        
        .sidebar-header {
            padding: 0 25px 20px 25px;
            border-bottom: 2px solid rgba(255, 255, 255, 0.2);
            margin-bottom: 20px;
        }
        
        .sidebar-header h2 {
            font-size: 1.4em;
            margin: 0 0 10px 0;
            color: #FFF;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }
        
        .sidebar-header p {
            font-size: 0.85em;
            opacity: 0.9;
            margin: 0;
        }
        
        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .sidebar-menu li {
            margin: 0;
        }
        
        .sidebar-menu a {
            display: block;
            padding: 12px 25px;
            color: white;
            text-decoration: none;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
            font-weight: 500;
            font-size: 0.95em;
        }
        
        .sidebar-menu a:hover {
            background: rgba(255, 255, 255, 0.15);
            border-left-color: #FFF;
            padding-left: 30px;
        }
        
        .sidebar-menu a.active {
            background: rgba(255, 255, 255, 0.2);
            border-left-color: #FFF;
            font-weight: 600;
        }
        
        /* Contenu principal */
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 40px 20px;
            background: #f8f9fa;
        }
        
        .container {
            max-width: 100%;
            margin: 0;
            padding: 0 20px;
        }
        
        /* Sections */
        .content-section {
            background: white;
            padding: 30px 20px;
            margin-bottom: 40px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        }
        
        .content-section h2 {
            font-size: 2.8rem;
            color: #FF6B35;
            margin-bottom: 50px;
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .content-section h2::before {
            content: attr(data-icon);
            font-size: 3rem;
            filter: drop-shadow(2px 2px 4px rgba(0,0,0,0.2));
        }
        
        /* Tableaux de formules */
        .formula-table {
            width: 100%;
            margin: 20px 0;
        }
        
        .formula-table table {
            width: 100%;
            border-collapse: collapse;
        }
        
        .formula-table thead {
            display: table;
            width: 100%;
            table-layout: fixed;
        }
        
        .formula-table th {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 18px 10px;
            text-align: left;
            font-weight: 600;
            font-size: 1.15rem;
        }
        
        .formula-table tbody {
            display: block;
            overflow: visible;
        }
        
        .formula-table tbody tr {
            display: table;
            width: 100%;
            table-layout: fixed;
            transition: all 0.3s ease;
            transform: scale(0.98);
            transform-origin: center;
        }
        
        .formula-table td {
            padding: 25px 10px;
            border-bottom: 1px solid #eee;
            font-size: 1.05rem;
            vertical-align: middle;
        }
        
        .formula-table tbody tr:hover {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
            transform: scale(1);
            transform-origin: center;
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.25), 
                        0 0 30px rgba(102, 126, 234, 0.15),
                        inset 0 1px 0 rgba(255, 255, 255, 0.5),
                        0 0 0 4px #FF9800,
                        0 0 0 8px #FFB74D;
            border-radius: 8px;
            position: relative;
            z-index: 10;
        }
        
        /* Navigation footer */
        .navigation-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 30px 40px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            margin-top: 40px;
        }
        
        .navigation-footer a {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 15px 30px;
            background: linear-gradient(135deg, #047857 0%, #14b8a6 100%);
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            box-shadow: 0 4px 10px rgba(4, 120, 87, 0.3);
        }
        
        .navigation-footer a:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(4, 120, 87, 0.4);
        }
        
        .navigation-footer .btn-prev::before {
            content: "←";
            font-size: 1.3rem;
        }
        
        .navigation-footer .btn-next::after {
            content: "→";
            font-size: 1.3rem;
        }
        
        /* Footer */
        .footer {
            background: #e9ecef;
            color: var(--text-dark);
            padding: 40px 20px;
            text-align: center;
            margin-top: 80px;
        }
        
        .footer p {
            margin: 10px 0;
            opacity: 0.9;
        }
        
        .footer strong {
            color: #047857;
        }
        
        .footer-links {
            margin-top: 20px;
        }
        
        .footer-links a {
            color: #047857;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        
        .footer-links a:hover {
            color: #14b8a6;
        }
        
        /* ══ STYLES PAGE DE GARDE SVG V2 ══ */
        :root {
            --green:   #1a5c35;
            --emerald: #22c55e;
            --blue:    #2563eb;
            --orange:  #f97316;
            --light:   #f0faf4;
            --white:   #ffffff;
            --smoke:   #64748b;
            --navy:    #1e3a5f;
        }
        
        .page {
            width: 210mm;
            min-height: 297mm;
            position: relative;
            display: flex;
            flex-direction: column;
            background: var(--white);
            overflow: hidden;
        }
        
        .cover-page {
            width: 210mm;
            min-height: 297mm;
            position: relative;
            display: flex;
            flex-direction: column;
            background: var(--white);
            overflow: hidden;
        }
        
        .stripe-left {
            position: absolute;
            top: 0;
            left: 0;
            width: 12mm;
            height: 100%;
            background: linear-gradient(to bottom, var(--green) 0%, var(--emerald) 55%, var(--orange) 100%);
            z-index: 10;
        }
        
        .stripe-left::after {
            content: '';
            position: absolute;
            top: 0;
            right: -5mm;
            width: 5mm;
            height: 100%;
            background: var(--orange);
            clip-path: polygon(0 0, 100% 12%, 100% 88%, 0 100%);
        }
        
        .tri-br {
            position: absolute;
            bottom: -3mm;
            right: 0;
            width: 0;
            height: 0;
            border-style: solid;
            border-width: 0 0 50mm 50mm;
            border-color: transparent transparent var(--green) transparent;
            z-index: 10;
        }
        
        .bg-schemas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }
        
        .cover-header {
            position: relative;
            z-index: 20;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 7mm 10mm 0 20mm;
        }
        
        .header-titles {
            display: flex;
            flex-direction: column;
            gap: 1mm;
        }
        
        .label-top {
            font-family: 'Oswald', sans-serif;
            font-size: 7pt;
            font-weight: 300;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--smoke);
        }
        
        .label-school {
            font-family: 'Oswald', sans-serif;
            font-size: 9.5pt;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--green);
        }
        
        .divider {
            position: relative;
            z-index: 20;
            margin: 4mm 10mm 0 20mm;
            height: 1px;
            background: linear-gradient(to right, var(--green) 0%, var(--emerald) 40%, var(--blue) 75%, transparent 100%);
        }
        
        .center-block {
            position: relative;
            z-index: 20;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 0 14mm 0 20mm;
            margin-top: 4mm;
        }
        
        .eyebrow {
            font-family: 'Oswald', sans-serif;
            font-size: 7.5pt;
            font-weight: 300;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--emerald);
            margin-bottom: 5mm;
        }
        
        .main-title {
            font-family: 'Oswald', sans-serif;
            font-size: 46pt;
            font-weight: 700;
            line-height: 0.92;
            text-transform: uppercase;
            color: var(--navy);
            margin-bottom: 2mm;
        }
        
        .main-title .accent-word {
            color: var(--blue);
        }
        
        .sub-title {
            font-family: 'Oswald', sans-serif;
            font-size: 22pt;
            font-weight: 500;
            color: var(--orange);
            letter-spacing: 5px;
            text-transform: uppercase;
            margin-bottom: 8mm;
        }
        
        .deco-rule {
            display: flex;
            align-items: center;
            gap: 3mm;
            margin-bottom: 7mm;
            max-width: 110mm;
        }
        
        .deco-rule::before {
            content: '';
            flex: 1;
            height: 1.5px;
            background: linear-gradient(to right, var(--emerald), var(--orange));
        }
        
        .deco-rule::after {
            content: '';
            width: 6px;
            height: 6px;
            background: var(--orange);
            border-radius: 50%;
            flex-shrink: 0;
        }
        
        .deco-rule span {
            font-family: 'Source Code Pro', monospace;
            font-size: 9pt;
            color: var(--orange);
        }
        
        .info-box {
            border-left: 4px solid var(--emerald);
            padding: 3mm 5mm;
            background: rgba(34, 197, 94, 0.07);
            max-width: 115mm;
        }
        
        .info-box p {
            font-family: 'EB Garamond', serif;
            font-size: 12pt;
            line-height: 1.6;
            color: var(--navy);
        }
        
        .logo-top {
            position: absolute;
            bottom: -3mm;
            left: 12mm;
            width: 32mm;
            height: auto;
            z-index: 9999;
            pointer-events: none;
        }
        
        .logo-top img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
    </style>
</head>
