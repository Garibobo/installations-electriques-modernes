        </aside>

        <!-- Contenu principal -->
        <main class="main-content">
            <div class="container">
                
                <!-- Page de garde SVG -->
                <div class="cover-page">
                    <!-- Bandes décoratives -->
                    <div class="stripe-left"></div>
                    <div class="tri-br"></div>

                    <!-- Arrière-plan SVG : schémas + formules -->
                    <svg class="bg-layer" viewBox="0 0 794 1123" xmlns="http://www.w3.org/2000/svg" style="position:absolute;inset:0;width:100%;height:100%;z-index:1;">
                        <!-- Schéma circuit série haut droite -->
                        <g opacity="0.07" transform="translate(370, 60)">
                            <line x1="0" y1="60" x2="340" y2="60" stroke="#1a5c35" stroke-width="3"/>
                            <line x1="0" y1="200" x2="340" y2="200" stroke="#1a5c35" stroke-width="3"/>
                            <line x1="0" y1="60" x2="0" y2="200" stroke="#1a5c35" stroke-width="3"/>
                            <line x1="340" y1="60" x2="340" y2="200" stroke="#1a5c35" stroke-width="3"/>
                            <!-- R1 -->
                            <line x1="0" y1="130" x2="50" y2="130" stroke="#1a5c35" stroke-width="3"/>
                            <rect x="50" y="112" width="70" height="36" stroke="#1a5c35" stroke-width="3" fill="none"/>
                            <line x1="120" y1="130" x2="170" y2="130" stroke="#1a5c35" stroke-width="3"/>
                            <text x="72" y="138" font-size="22" fill="#1a5c35" font-family="serif" font-style="italic">R₁</text>
                            <!-- R2 -->
                            <line x1="170" y1="130" x2="220" y2="130" stroke="#1a5c35" stroke-width="3"/>
                            <rect x="220" y="112" width="70" height="36" stroke="#1a5c35" stroke-width="3" fill="none"/>
                            <line x1="290" y1="130" x2="340" y2="130" stroke="#1a5c35" stroke-width="3"/>
                            <text x="242" y="138" font-size="22" fill="#1a5c35" font-family="serif" font-style="italic">R₂</text>
                            <!-- Nœuds -->
                            <circle cx="0" cy="130" r="5" fill="#1a5c35"/>
                            <circle cx="340" cy="130" r="5" fill="#1a5c35"/>
                            <!-- Labels -->
                            <text x="0" y="100" font-size="20" fill="#1a5c35" font-family="serif" font-weight="bold">+</text>
                            <text x="325" y="100" font-size="20" fill="#1a5c35" font-family="serif">–</text>
                            <!-- U source -->
                            <line x1="170" y1="60" x2="170" y2="112" stroke="#1a5c35" stroke-width="2" stroke-dasharray="6,4"/>
                            <text x="176" y="95" font-size="20" fill="#1a5c35" font-family="serif" font-style="italic">U</text>
                        </g>

                        <!-- Schéma circuit parallèle milieu gauche -->
                        <g opacity="0.06" transform="translate(60, 320)">
                            <!-- Rails -->
                            <line x1="20" y1="20" x2="300" y2="20" stroke="#2563eb" stroke-width="3"/>
                            <line x1="20" y1="200" x2="300" y2="200" stroke="#2563eb" stroke-width="3"/>
                            <line x1="20" y1="20" x2="20" y2="200" stroke="#2563eb" stroke-width="3"/>
                            <line x1="300" y1="20" x2="300" y2="200" stroke="#2563eb" stroke-width="3"/>
                            <!-- Branche 1 -->
                            <line x1="80" y1="20" x2="80" y2="72" stroke="#2563eb" stroke-width="2.5"/>
                            <rect x="60" y="72" width="40" height="70" stroke="#2563eb" stroke-width="2.5" fill="none"/>
                            <line x1="80" y1="142" x2="80" y2="200" stroke="#2563eb" stroke-width="2.5"/>
                            <text x="68" y="113" font-size="20" fill="#2563eb" font-family="serif" font-style="italic">R₁</text>
                            <!-- Branche 2 -->
                            <line x1="160" y1="20" x2="160" y2="72" stroke="#2563eb" stroke-width="2.5"/>
                            <rect x="140" y="72" width="40" height="70" stroke="#2563eb" stroke-width="2.5" fill="none"/>
                            <line x1="160" y1="142" x2="160" y2="200" stroke="#2563eb" stroke-width="2.5"/>
                            <text x="148" y="113" font-size="20" fill="#2563eb" font-family="serif" font-style="italic">R₂</text>
                            <!-- Branche 3 -->
                            <line x1="240" y1="20" x2="240" y2="72" stroke="#2563eb" stroke-width="2.5"/>
                            <rect x="220" y="72" width="40" height="70" stroke="#2563eb" stroke-width="2.5" fill="none"/>
                            <line x1="240" y1="142" x2="240" y2="200" stroke="#2563eb" stroke-width="2.5"/>
                            <text x="228" y="113" font-size="20" fill="#2563eb" font-family="serif" font-style="italic">R₃</text>
                            <!-- Source -->
                            <circle cx="300" cy="110" r="26" stroke="#f97316" stroke-width="2.5" fill="none"/>
                            <text x="291" y="117" font-size="22" fill="#f97316" font-family="serif" font-style="italic">U</text>
                        </g>

                        <!-- Formules mathématiques fond droit bas -->
                        <g opacity="0.065" transform="translate(380, 480)" font-family="Georgia, serif" font-style="italic" fill="#1a5c35">
                            <text x="0" y="0" font-size="28">U = R · I</text>
                            <text x="0" y="55" font-size="28">P = U · I = R · I²</text>
                            <text x="0" y="110" font-size="22">R<tspan font-size="16" dy="6">e</tspan><tspan dy="-6"> = </tspan><tspan font-size="18">R₁ + R₂ + R₃</tspan></text>
                            <text x="0" y="160" font-size="22">1/R<tspan font-size="16" dy="5">e</tspan><tspan dy="-5"> = 1/R₁ + 1/R₂</tspan></text>
                            <text x="0" y="210" font-size="28">η = P₂ / P₁</text>
                            <text x="0" y="265" font-size="22">cos φ = P / S</text>
                            <text x="0" y="315" font-size="22">S = U · I</text>
                            <text x="0" y="365" font-size="22">Q = √(S²− P²)</text>
                            <text x="0" y="415" font-size="22">τ = L / R</text>
                        </g>

                        <!-- Bobine décorative bas gauche -->
                        <g opacity="0.06" transform="translate(55, 700)">
                            <line x1="0" y1="40" x2="30" y2="40" stroke="#1a5c35" stroke-width="3"/>
                            <path d="M30,40 C30,20 50,20 50,40 C50,60 70,60 70,40 C70,20 90,20 90,40 C90,60 110,60 110,40 C110,20 130,20 130,40" stroke="#1a5c35" stroke-width="3" fill="none"/>
                            <line x1="130" y1="40" x2="160" y2="40" stroke="#1a5c35" stroke-width="3"/>
                            <text x="55" y="80" font-size="20" fill="#1a5c35" font-family="serif" font-style="italic">L</text>
                            <!-- Condensateur -->
                            <line x1="200" y1="40" x2="245" y2="40" stroke="#1a5c35" stroke-width="3"/>
                            <line x1="245" y1="15" x2="245" y2="65" stroke="#1a5c35" stroke-width="4"/>
                            <line x1="255" y1="15" x2="255" y2="65" stroke="#1a5c35" stroke-width="4"/>
                            <line x1="255" y1="40" x2="300" y2="40" stroke="#1a5c35" stroke-width="3"/>
                            <text x="218" y="80" font-size="20" fill="#1a5c35" font-family="serif" font-style="italic">C</text>
                        </g>

                        <!-- Triangle de puissance bas droite -->
                        <g opacity="0.065" transform="translate(470, 760)">
                            <polygon points="0,120 220,120 220,0" stroke="#2563eb" stroke-width="2.5" fill="none"/>
                            <text x="100" y="140" font-size="20" fill="#2563eb" font-family="serif" font-style="italic">P</text>
                            <text x="230" y="65" font-size="20" fill="#2563eb" font-family="serif" font-style="italic">Q</text>
                            <text x="95" y="65" font-size="22" fill="#f97316" font-family="serif" font-style="italic">S</text>
                            <!-- angle phi -->
                            <path d="M0,120 A40,40 0 0,1 33,107" stroke="#1a5c35" stroke-width="2" fill="none"/>
                            <text x="36" y="116" font-size="18" fill="#1a5c35" font-family="serif" font-style="italic">φ</text>
                        </g>
                    </svg>

