    <body>
        <div class="page-wrapper">
            <aside class="sidebar">
                <div class="sidebar-header">
                    <h2>📐 Formulaires</h2>
                    <p>Navigation rapide</p>
                    <li style="padding-left: 20px;"><a href="chapitre-3.html#rendement">↳ 03.3 Rendement</a></li>
